{
    "name": "shamimstack/servertheme",
    "description": "Unified DhruFusion API client for Laravel, supporting both Standard and Pro versions.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Shamim",
            "email": "shamimstack@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^12.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "orchestra/testbench": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "ShamimStack\\ServerTheme\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ShamimStack\\ServerTheme\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ShamimStack\\ServerTheme\\ServerThemeServiceProvider"
            ],
            "aliases": {
                "ServerTheme": "ShamimStack\\ServerTheme\\Facades\\ServerTheme"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
